<mvc:View controllerName="productui.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="Product Catalog">
        <Table id="productTable" items="{/Products}">
            <headerToolbar>
                <Toolbar id="_IDGenToolbar1">
                    <Title id="_IDGenTitle" text="Products"/>
                </Toolbar>
            </headerToolbar>
            <columns>
                <Column id="_IDGenColumn"><Text id="_IDGenText" text="ID"/></Column>
                <Column id="_IDGenColumn1"><Text id="_IDGenText1" text="Name"/></Column>
                <Column id="_IDGenColumn2"><Text id="_IDGenText2" text="Price"/></Column>
                <Column id="_IDGenColumn3"><Text id="_IDGenText3" text="Stock"/></Column>
            </columns>
            <items>
                <ColumnListItem id="_IDGenColumnListItem">
                    <cells>
                        <Text id="_IDGenText4" text="{ProductID}"/>
                        <Text id="_IDGenText5" text="{ProductName}"/>
                        <Text id="_IDGenText6" text="{UnitPrice}"/>
                        <Text id="_IDGenText7" text="{UnitsInStock}"/>
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </Page>
</mvc:View>
